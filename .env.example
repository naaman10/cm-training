# Auth0 — create a Regular Web Application in the Auth0 Dashboard
AUTH0_DOMAIN=your-tenant.region.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# openssl rand -hex 32
AUTH0_SECRET=

APP_BASE_URL=http://localhost:3000

# Training API Identifier (same as backend AUTH0_AUDIENCE). Required for portal `/api/auth/me`
# integration; app requests access tokens with this audience.
AUTH0_AUDIENCE=https://cm-training-api.onrender.com

# Server-side origin for CM Training REST API (no trailing slash). Prefer this over
# NEXT_PUBLIC for BFF/route handlers — not exposed to the browser.
CM_TRAINING_API_URL=https://cm-training-api.onrender.com

# Public duplicate (legacy / client-visible). Falls back when CM_TRAINING_API_URL unset.
NEXT_PUBLIC_CM_TRAINING_API_URL=https://cm-training-api.onrender.com

# Production: exact origin the API allows via CORS (FRONTEND_ORIGIN on the API).
# Use the real deployed site URL when building/deploying production.
NEXT_PUBLIC_FRONTEND_ORIGIN=http://localhost:3000

# Optional: namespaced claim for dashboard role label (Actions / RBAC)
# AUTH0_ROLE_CLAIM=https://your-app.example.com/roles
